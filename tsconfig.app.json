{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "react": [
        "vendor/react/index.d.ts"
      ],
      "react/jsx-runtime": [
        "vendor/react/jsx-runtime.d.ts"
      ],
      "react-dom/client": [
        "vendor/react-dom/client.d.ts"
      ]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src"
  ]
}
